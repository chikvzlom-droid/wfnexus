  "notifications": {
    "on_new_conversation": {
      "system_notify": {
        "enabled": true,
        "title": "New Conversation",
        "content": "From: <PLAYER_NAME>",
        "sound_file": "cat_meow.mp3",
        "volume": 1.0
      },
      "discord_notify": {
        "enabled": true,
        "content": "<MENTION>\n```ansi\n\u001b[1;36m🗨️ New Conversation\n\n\u001b[1;33m👤 From Player:\u001b[0m \u001b[1;37m<PLAYER_NAME>\u001b[0m\n```",
        "webhook": "",
        "user_ids": []
      },
      "webhook_notify": {
        "enabled": false,
        "url": "<WEBHOOK_URL>"
      }
    },
    "on_wfm_chat_message": {
      "system_notify": {
        "enabled": true,
        "title": "New Warframe Market Message",
        "content": "Chat Name: <CHAT_NAME> | From: <FROM_USER> | Message: \n <WFM_MESSAGE>",
        "sound_file": "cat_meow.mp3",
        "volume": 1.0
      },
      "discord_notify": {
        "enabled": true,
        "content": "<MENTION>\n```ansi\n\u001b[1;36m🗨️ New Warframe Market Message\u001b[0m\n\n\u001b[1;32m📀 Chat Name:        \u001b[0m   \u001b[0;32m<CHAT_NAME>\u001b[0m\n\u001b[1;33m👤 From Player:   \u001b[0m \u001b[1;37m<FROM_USER>\u001b[0m\n\n\u001b[1;34m✨ Context\u001b[0m\n<WFM_MESSAGE>\n\n```",
        "webhook": "",
        "user_ids": []
      },
      "webhook_notify": {
        "enabled": false,
        "url": "<WEBHOOK_URL>"
      }
    },
    "on_new_trade": {
      "system_notify": {
        "enabled": true,
        "title": "Item <TR_TYPE>",
        "content": "From: <PLAYER_NAME>\nOffered: <OF_COUNT> Received: <RE_COUNT> Plat: <TOTAL_PLAT>",
        "sound_file": "cat_meow.mp3",
        "volume": 1.0
      },
      "discord_notify": {
        "enabled": true,
        "content": "<MENTION>\n```ansi\n\u001b[1;36m💱 Player Trade\u001b[0m\n\n\u001b[1;33m👤 Player:   \u001b[0m \u001b[1;37m<PLAYER_NAME>\u001b[0m\n\u001b[1;33m🕒 Time:   \u001b[0m   \u001b[0;32m<TIME>\u001b[0m\n\u001b[1;33m📂 Type:   \u001b[0m   \u001b[0;35m<TR_TYPE>\u001b[0m\n\u001b[1;33m💎 Platinum: \u001b[0m \u001b[1;37m<TOTAL_PLAT>\u001b[0m\n\n\u001b[1;34m📤 Offered Items\u001b[0m\n<OF_ITEMS>\n\n\u001b[1;32m📥 Received Items\u001b[0m\n<RE_ITEMS>\n\n```",
        "webhook": "",
        "user_ids": []
      },
      "webhook_notify": {
        "enabled": false,
        "url": "<WEBHOOK_URL>"
      }
    }
  },
